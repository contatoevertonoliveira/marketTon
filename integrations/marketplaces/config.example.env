# Configuração de marketplaces — copie para .env e preencha
#
# Modos por marketplace: affiliate | dropshipping | both | national | international
# Scope de fornecedor: national, international, ambos

# Mercado Livre
MARKETPLACE_MERCADOLIVRE_ENABLED=true
MARKETPLACE_MERCADOLIVRE_MODE=affiliate
MARKETPLACE_MERCADOLIVRE_SCOPE=national,international
MARKETPLACE_MERCADOLIVRE_API_URL=https://api.mercadolibre.com
MARKETPLACE_MERCADOLIVRE_CLIENT_ID=
MARKETPLACE_MERCADOLIVRE_CLIENT_SECRET=
MARKETPLACE_MERCADOLIVRE_ACCESS_TOKEN=
MARKETPLACE_MERCADOLIVRE_COUNTRY=BR
MARKETPLACE_MERCADOLIVRE_CURRENCY=BRL

# Shopee
MARKETPLACE_SHOPEE_ENABLED=true
MARKETPLACE_SHOPEE_MODE=affiliate
MARKETPLACE_SHOPEE_SCOPE=national,international
MARKETPLACE_SHOPEE_API_URL=https://partner.shopeemobile.com
MARKETPLACE_SHOPEE_PARTNER_ID=
MARKETPLACE_SHOPEE_PARTNER_KEY=
MARKETPLACE_SHOPEE_ACCESS_TOKEN=
MARKETPLACE_SHOPEE_COUNTRY=BR
MARKETPLACE_SHOPEE_CURRENCY=BRL

# Amazon (Associados / PA API)
MARKETPLACE_AMAZON_ENABLED=true
MARKETPLACE_AMAZON_MODE=affiliate
MARKETPLACE_AMAZON_SCOPE=international
MARKETPLACE_AMAZON_API_URL=https://webservices.amazon.com
MARKETPLACE_AMAZON_ACCESS_KEY=
MARKETPLACE_AMAZON_SECRET_KEY=
MARKETPLACE_AMAZON_ASSOCIATE_TAG=
MARKETPLACE_AMAZON_REGION=us-east-1
MARKETPLACE_AMAZON_COUNTRY=US
MARKETPLACE_AMAZON_CURRENCY=USD

# Comportamento do agente scanner
AGENT_SCAN_INTERVAL_MINUTES=60
AGENT_MIN_COMMISSION_PCT=5.0
AGENT_TARGET_TICKET_MIN=97.0
AGENT_TARGET_TICKET_MAX=297.0
AGENT_MIN_ORDERS=50
AGENT_SCORE_WEIGHTS={"commission":0.4,"orders":0.3,"ticket":0.2,"competition":0.1}
AGENT_PREFERRED_SUPPLIER_SCOPE=national,international
AGENT_ALLOW_DROPSHIPPING=true
AGENT_ALLOW_AFFILIATE=true
